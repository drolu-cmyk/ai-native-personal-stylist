# syntax=docker/dockerfile:1.7

ARG NODE_VERSION=20
FROM node:${NODE_VERSION}-bookworm-slim AS base

ENV PNPM_HOME="/pnpm"
ENV PATH="/pnpm:$PATH"
ENV NEXT_TELEMETRY_DISABLED=1
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

FROM base AS deps
ENV NODE_ENV=development
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/package.json
COPY apps/api/package.json apps/api/package.json
COPY packages/shared/package.json packages/shared/package.json
RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store pnpm install --frozen-lockfile --prod=false

FROM deps AS build
ENV NODE_ENV=production
ENV APP_ENV=production
ENV PUBLIC_APP_NAME=Personal-Stylist
ENV PUBLIC_WEB_URL=http://localhost:3000
ENV API_BASE_URL=http://localhost:4000
ENV NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
ENV API_PORT=4000
ENV AI_PROVIDER=openai
ENV VOICE_STT_PROVIDER=google
ENV VOICE_TTS_PROVIDER=google
ENV VISION_PROVIDER=aws
ENV WEATHER_PROVIDER=weatherapi
ENV MAPS_PROVIDER=google
ENV AUTH_PROVIDER=aws-cognito
ENV DATABASE_PROVIDER=aws-dynamodb
ENV OBJECT_STORAGE_PROVIDER=aws-s3
ENV OBSERVABILITY_PROVIDER=aws-cloudwatch
ENV HOSTING_PROVIDER=aws-ecs
ENV CORS_ORIGINS=http://localhost:3000
ENV RATE_LIMIT_MAX=100
ENV MAX_IMAGE_UPLOAD_MB=8
COPY . .
RUN pnpm build

FROM base AS runtime
ENV NODE_ENV=production
ENV API_PORT=4000
COPY --from=build --chown=node:node /app /app
USER node
EXPOSE 4000
CMD ["node", "apps/api/dist/index.js"]
