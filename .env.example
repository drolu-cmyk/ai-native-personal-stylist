# Copy to .env.local for local development only. Never commit real values.
NODE_ENV=development
APP_ENV=local
PUBLIC_APP_NAME="AI Native Personal Stylist"
PUBLIC_WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
API_PORT=4000

# Provider selection keeps the app cloud-agnostic.
# Supported values: openai, google, aws, mock
AI_PROVIDER=mock
VOICE_STT_PROVIDER=mock
VOICE_TTS_PROVIDER=mock
VISION_PROVIDER=mock
WEATHER_PROVIDER=mock
MAPS_PROVIDER=mock

# Optional provider credentials. Leave blank locally unless needed.
OPENAI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Security and operational controls.
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
MAX_IMAGE_UPLOAD_MB=8
ENABLE_REQUEST_LOGGING=true
ENABLE_ECOMMERCE=false
ENABLE_MAPS=false
ENABLE_TRANSIT=false
