# Copy to .env.local for local development only. Never commit real values.
NODE_ENV=development
APP_ENV=local
PUBLIC_APP_NAME="AI Native Personal Stylist"
PUBLIC_WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_PORT=4000

# Provider selection keeps the app portable.
# Supported values: openai, google, aws, mock
AI_PROVIDER=mock
VOICE_STT_PROVIDER=mock
VOICE_TTS_PROVIDER=mock
VISION_PROVIDER=mock
WEATHER_PROVIDER=mock
MAPS_PROVIDER=mock

# Public release preference.
# Set VOICE_TTS_PROVIDER=google and MAPS_PROVIDER=google for the first live voice and maps path.

# Optional provider credentials. Use local or managed secret stores; never commit real values.
AI_PROVIDER_API_KEY=
VOICE_STT_PROVIDER_API_KEY=
VOICE_TTS_PROVIDER_API_KEY=
VISION_PROVIDER_API_KEY=
WEATHER_PROVIDER_API_KEY=
MAPS_PROVIDER_API_KEY=
PROVIDER_PROJECT_ID=
PROVIDER_REGION=

# Security and operational controls.
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
MAX_IMAGE_UPLOAD_MB=8
ENABLE_REQUEST_LOGGING=true
ENABLE_ECOMMERCE=false
ENABLE_MAPS=false
ENABLE_TRANSIT=false
