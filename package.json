{
  "name": "ai-native-personal-stylist",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud-portable AI-native personal styling application.",
  "packageManager": "pnpm@9.15.4",
  "engines": { "node": ">=20.11.0", "pnpm": ">=9.0.0" },
  "scripts": {
    "dev": "pnpm --parallel --filter @stylist/web --filter @stylist/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "validate:env": "node scripts/validate-env.mjs",
    "security:audit": "pnpm audit --audit-level moderate"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "typescript": "^5.7.3"
  }
}
